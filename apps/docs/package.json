{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm generate && next build",
    "dev": "pnpm generate && next dev -p 3002",
    "start": "next start -p 3002",
    "generate": "tsx scripts/generate-docs.ts",
    "types:check": "pnpm generate && fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "fumadocs-core": "16.10.5",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-openapi": "11.0.3",
    "fumadocs-ui": "16.10.5",
    "lucide-react": "^1.20.0",
    "mermaid": "^11.15.0",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@theguild/remark-mermaid": "^0.3.0",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "postcss": "^8.5.15",
    "swagger-jsdoc": "^6.2.8",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.1.0"
  }
}