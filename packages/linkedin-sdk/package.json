{
  "name": "@linkedin-job-applier/linkedin-sdk",
  "version": "1.0.0",
  "description": "SDK Unificado para o ecossistema de vagas, publicação de posts e GraphQL do LinkedIn",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "graphql": "^16.10.0"
  },
  "peerDependencies": {
    "@linkedin-job-applier/job-backend": "workspace:*",
    "linkedin-publisher-backend": "workspace:*",
    "@linkedin-job-applier/graphql-linkedin": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@linkedin-job-applier/job-backend": {
      "optional": true
    },
    "linkedin-publisher-backend": {
      "optional": true
    },
    "@linkedin-job-applier/graphql-linkedin": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.3.6",
    "typescript": "~5.8.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
