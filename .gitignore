```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
.next/
.nuxt/
out/

# TypeScript/JavaScript
*.tsbuildinfo
*.js.map
*.ts.map

# Environment variables
.env
.env.local
.env.*
!.env.example

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Coverage
coverage/
.nyc_output/
```